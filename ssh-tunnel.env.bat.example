@echo off
rem ============================================================
rem LLM Relay Desk two-hop SSH tunnel configuration
rem
rem Route:
rem   localhost:11435
rem     -> jump host on the 10.x network
rem     -> vLLM host on the 192.x network
rem     -> target host localhost:8000
rem ============================================================

rem Jump host on the 10.x network
set "SSH_JUMP_HOST=10.0.0.10"
set "SSH_JUMP_PORT=22"
set "SSH_JUMP_USER=jump_user"

rem Leave empty to use ssh-agent or the OpenSSH default key.
set "SSH_JUMP_IDENTITY_FILE=%USERPROFILE%\.ssh\id_ed25519"

rem vLLM server on the 192.x network
set "SSH_TARGET_HOST=192.168.1.20"
set "SSH_TARGET_PORT=22"
set "SSH_TARGET_USER=vllm_user"

rem Leave empty to use ssh-agent or the OpenSSH default key.
set "SSH_TARGET_IDENTITY_FILE=%USERPROFILE%\.ssh\id_ed25519"

rem Local endpoint used by LLM Relay Desk:
rem   http://127.0.0.1:11435/v1
set "SSH_LOCAL_PORT=11435"

rem vLLM endpoint as seen from the final SSH target.
set "VLLM_REMOTE_HOST=127.0.0.1"
set "VLLM_REMOTE_PORT=8000"

rem SSH behavior
set "SSH_CONNECT_TIMEOUT_SECONDS=15"
set "SSH_SERVER_ALIVE_INTERVAL=30"
set "SSH_SERVER_ALIVE_COUNT_MAX=3"
set "SSH_STRICT_HOST_KEY_CHECKING=accept-new"
